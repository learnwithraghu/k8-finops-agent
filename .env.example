# K8s FinOps Agent Environment Configuration
# Local Docker/Kind profile
# Mount kubeconfig to /home/finops/.kube/config when running the container.

# ============================================
# AWS Configuration (Bedrock via IAM user credentials)
# ============================================
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY
AWS_SESSION_TOKEN=
AWS_REGION=us-east-1

# ============================================
# GitHub Configuration (mocked for local testing)
# ============================================
GITHUB_TOKEN=mock-github-token
GITHUB_REPO=mock-org/tech-debt

# ============================================
# Infrastructure Configuration
# ============================================
INSTANCE_TYPE=t2.medium
AWS_PRICING_REGION=us-east-1

# ============================================
# Kubernetes Configuration
# ============================================
KUBECONFIG_PATH=~/.kube/config
PRICING_CONFIG=sections/04-local-python-agent/config/pricing.yaml
TAGGING_RULES=sections/04-local-python-agent/config/tagging-rules.yaml

# ============================================
# Agent Configuration
# ============================================
LOG_LEVEL=DEBUG
DRY_RUN=true
MIN_COST_THRESHOLD=1.0
USE_MOCK=true
USE_MOCK_GITHUB=true

# ============================================
# Bedrock Configuration
# ============================================
BEDROCK_MODEL_ID=anthropic.claude-3-5-haiku-20241022-v1:0
BEDROCK_MAX_TOKENS=1024
BEDROCK_TEMPERATURE=0.3
