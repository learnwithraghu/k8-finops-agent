# K8s FinOps Agent Environment Configuration
# Local Docker/Kind profile
# Mount kubeconfig to /home/finops/.kube/config when running the container.

# ============================================
# Kubernetes Configuration
# ============================================
KUBECONFIG_PATH=~/.kube/config
PRICING_CONFIG=sections/04-local-python-agent/config/pricing.yaml
TAGGING_RULES=sections/04-local-python-agent/config/tagging-rules.yaml

# ============================================
# Agent Configuration
# ============================================
LOG_LEVEL=DEBUG
DRY_RUN=false
MIN_COST_THRESHOLD=1.0
ISSUE_TRACKER_URL=http://localhost:8085
ISSUE_TRACKER_TIMEOUT=10

# ============================================
# OpenAI-Compatible Endpoint Configuration
# ============================================
OPENAI_BASE_URL=https://api.ai.kodekloud.com/v1
OPENAI_API_KEY=your-api-key-here
OPENAI_MODEL_ID=gpt-4o
OPENAI_MAX_TOKENS=1024
OPENAI_TEMPERATURE=0.3
